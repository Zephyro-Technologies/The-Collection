# Supabase project credentials for The Collection dashboard.
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# These are exposed to the browser (Vite inlines `VITE_`-prefixed vars), so only
# the *anon* (public) key belongs here — never the service_role key. Row Level
# Security policies in supabase/migrations protect the data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
