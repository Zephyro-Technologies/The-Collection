# Supabase project credentials for The Collection website (public, read-only).
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# These are exposed to the browser (Vite inlines `VITE_`-prefixed vars), so only
# the *anon* (public) key belongs here — never the service_role key. The website
# only READS inventory; writes are the dashboard's job and are protected by Row
# Level Security. This is the same Supabase project the dashboard uses.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
