# Dependencies
node_modules/

# Build output
dist/
.vite/

# Cloudflare Wrangler local state / cache (never commit)
.wrangler/

# Environment — never commit real keys
.env
.env.*
!.env.example

# Wrangler's local runtime-secrets file. Unused by this setup (the Workers are
# assets-only and have no runtime bindings), but must never be committed if one
# is ever created.
.dev.vars
.dev.vars.*

# Editor / OS
.DS_Store
*.log
.idea/

# Supabase CLI local state
supabase/.branches/
supabase/.temp/
